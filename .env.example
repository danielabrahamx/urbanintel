# Copy to .env and fill in real values

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# TfL Unified API - register free at https://api-portal.tfl.gov.uk
# Use your primary key. app_id is deprecated - only app_key is needed.
TFL_APP_KEY=

# =============================================================================
# API KEYS (at least one vision provider required)
# =============================================================================

# OpenRouter API for minimax/minimax-m3 vision model (https://openrouter.ai/keys)
# Recommended - faster and cheaper than Gemini for video analysis
OPENROUTER_API_KEY=

# Gemini vision API - alternative vision provider (https://aistudio.google.com/apikey)
# Used by main.py and eval.py
GEMINI_API_KEY=

# =============================================================================
# OPTIONAL: VISION MODEL SETTINGS
# =============================================================================

# Vision model to use for video analysis (default: minimax/minimax-m3)
# Other options: google/gemini-2.0-flash-001, qwen/qwen2.5-vl-72b-instruct, etc.
# See https://openrouter.ai/models for available vision models
# VISION_MODEL=minimax/minimax-m3

# Custom analysis prompt - overrides the default incident detection prompt
# Use {incident_types} placeholder to include the list of incident types
# ANALYSIS_PROMPT=

# =============================================================================
# OPTIONAL: CAMERA & POLLING SETTINGS
# =============================================================================

# Target camera ID to monitor (default: JamCams_00001.07350)
# Run list_cameras.py to find available cameras with video URLs
# TARGET_CAMERA_ID=JamCams_00001.07350

# Polling interval in seconds (default: 180 = 3 minutes)
# Minimum 60s recommended to avoid rate limits
# POLL_INTERVAL_SECONDS=180

# Alert threshold - minimum severity to trigger alerts (default: medium)
# Options: none, low, medium, high, critical
# ALERT_THRESHOLD=medium

# =============================================================================
# OPTIONAL: TfL API SETTINGS
# =============================================================================

# TfL API URL (default: https://api.tfl.gov.uk/Place/Type/JamCam)
# Only change if TfL updates their API endpoint
# TFL_API_URL=https://api.tfl.gov.uk/Place/Type/JamCam

# Deprecated - kept for backward compatibility with old code
# TfL stopped requiring app_id, only app_key is needed now
# TFL_APP_ID=

# =============================================================================
# OPTIONAL: API SERVER SETTINGS
# =============================================================================

# API server host and port (defaults: 0.0.0.0, 8000)
# API_HOST=0.0.0.0
# API_PORT=8000

# CORS origins for frontend access (default: http://localhost:3000, https://localhost:3000)
# Comma-separated list of allowed origins
# CORS_ORIGINS=http://localhost:3000,https://localhost:3000

# =============================================================================
# OPTIONAL: SUPABASE DATABASE
# =============================================================================

# Supabase project URL and keys (https://supabase.com/dashboard/project/<id>/settings/api)
# Service role key is required for backend writes to incidents table
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =============================================================================
# OPTIONAL: MUBIT AI MEMORY (hackathon points)
# =============================================================================

# MuBit enables continual learning for your AI agent — it remembers past
# incidents per camera and injects that context into future analysis prompts.
# Sign up at https://console.mubit.ai for an API key.
# MUBIT_API_KEY=mbt_<instance>_<key_id>_<secret>
# MUBIT_PROJECT_ID=proj-a53a9329-6dc1-428e-8dd8-ebf89705ee9c
# MUBIT_ENDPOINT=https://api.mubit.ai

# =============================================================================
# OPTIONAL: ADVANCED OPENROUTER SETTINGS
# =============================================================================

# OpenRouter API base URL (default: https://openrouter.ai/api/v1/chat/completions)
# Only change if using a proxy or different endpoint
# OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
