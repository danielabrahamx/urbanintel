# Copy to .env and fill in real values

# TfL Unified API - register free at https://api-portal.tfl.gov.uk
# Use your primary key. app_id is deprecated - only app_key is needed.
TFL_APP_KEY=

# Gemini vision API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Supabase (https://supabase.com/dashboard/project/<id>/settings/api)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
