# Copy to .env.local and fill in real values

# Supabase (same as root .env)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# TfL API - needed for frontend to fetch camera list
# Get your free key at: https://api-portal.tfl.gov.uk
NEXT_PUBLIC_TFL_APP_KEY=

# Backend API URL (for video analysis)
# Use localhost for development, production URL for deploy
NEXT_PUBLIC_API_URL=http://localhost:8000

# OpenRouter API key (for video analysis backend)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
